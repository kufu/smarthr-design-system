{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noEmit": true,
    "skipLibCheck": true
  },
  "extends": "astro/tsconfigs/strict",
  "include": ["src"],
  "exclude": ["dist", "scripts"]
}
