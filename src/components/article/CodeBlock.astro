---
import ReactCodeBlock from '@/components/CodeBlock';

type Props = {
  code: string;
  language?: string;
  meta?: string;
  editable?: boolean;
  noIframe?: boolean;
  isStorybook?: boolean;
  renderingComponent?: string;
  componentTitle?: string;
  withStyled?: boolean;
  gap?: any;
  align?: any;
  layout?: 'none' | 'product';
  canvas?: number;
};

type MetaProps = {
  [key: string]: string | boolean;
};

/**
 * editable layout="product" のようなメタ情報をパースする
 * @param meta - スペース区切りのメタ情報
 * @returns メタ情報をキーとしたオブジェクト
 */
const parseMeta = (meta: string | undefined): MetaProps => {
  if (!meta) {
    return {};
  }

  const result: MetaProps = {};
  const items = meta.split(' ');

  for (const item of items) {
    const [key, value] = item.split('=');
    result[key] = value ? value : true;
  }

  return result;
};

const {
  code,
  language,
  meta,
  editable,
  noIframe,
  isStorybook,
  renderingComponent,
  componentTitle,
  withStyled,
  gap,
  align,
  layout,
  canvas,
} = Astro.props;

const metaProps = parseMeta(meta);
const _code: string = metaProps?.code && typeof metaProps.code === 'string' ? metaProps.code : code;
const _language: string = metaProps?.language && typeof metaProps.language === 'string' ? metaProps.language : language || '';
const _editable = metaProps?.editable && typeof metaProps.editable === 'boolean' ? metaProps.editable : editable;
---

<ReactCodeBlock
  {...metaProps}
  client:only="react"
  code={_code}
  language={_language}
  editable={_editable}
  noIframe={noIframe}
  isStorybook={isStorybook}
  renderingComponent={renderingComponent}
  componentTitle={componentTitle}
  withStyled={withStyled}
  gap={gap}
  align={align}
  layout={layout}
  canvas={canvas || (metaProps.canvas ? Number(metaProps.canvas) : undefined)}
/>
