---
import { getCollection } from 'astro:content';

import { ChecklistPanel } from './ChecklistPanel';

type Variant = 'grouped' | 'table';

type Props = {
  /** コンポーネント名（ComponentStory と同じ PascalCase。例: Button / ActionDialog） */
  name: string;
  /** 見せ方の試作バリエーション（比較用。確定後は単一案に集約予定） */
  variant?: Variant;
  /** 見出しに表示する名前。省略時は name をそのまま使う */
  title?: string;
  /** タイトルを見出しとして表示するか。true で h3 見出し（目次に含む）、未指定時は span にして見出し階層・目次に含めない */
  showTitle?: boolean;
};

const { name, variant = 'grouped', title, showTitle = false } = Astro.props;

// PascalCase の name を checklist.yaml のディレクトリ id（kebab-case）に変換（例: Button → button, ActionDialog → action-dialog）
const dirName = name.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();

// yamlGlobLoader の defaultId はファイル相対パスから拡張子を落としたもの（例: button/checklist.yaml → "button/checklist"）。
// ネストしたサブコンポーネントにも対応するため、末尾一致でも引く（例: dialog/action-dialog/checklist）。
const checklists = await getCollection('checklists');
const entry = checklists.find((c) => c.id === `${dirName}/checklist` || c.id.endsWith(`/${dirName}/checklist`));

if (!entry) {
  throw new Error(`checklist が見つかりませんでした: name=${name} (dirName=${dirName})`);
}

const items = entry.data.items;

// source_section ごとにグループ化（初出順を保持）
const groups: Array<{ section: string; items: typeof items }> = [];
for (const item of items) {
  let group = groups.find((g) => g.section === item.source_section);
  if (!group) {
    group = { section: item.source_section, items: [] };
    groups.push(group);
  }
  group.items.push(item);
}

// Disclosure / 見出しアンカーに使う一意な DOM id
const panelId = `checklist-${dirName}-${variant}`;

const displayName = title ?? name;

// showTitle 指定時は h3 見出し、未指定時は span（見出しにせず目次に含めない）
const resolvedHeadingTag = showTitle ? 'h3' : 'span';
---

<ChecklistPanel client:visible groups={groups} variant={variant} id={panelId} title={displayName} headingTag={resolvedHeadingTag} />
