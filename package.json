{
  "name": "smarthr-design-system",
  "description": "Documentation page for SmartHR's design system",
  "author": "SmartHR Design System Team",
  "license": "MIT",
  "type": "module",
  "lint-staged": {
    "src/**/*.{astro,ts,tsx}": [
      "pnpm prelint",
      "pnpm run-p lint:ts:content lint:ts:codeblock lint:check -- ",
      "pnpm run-p format:eslint format:prettier -- "
    ],
    "src/**/*.md{,x}": [
      "pnpm prelint",
      "pnpm run-p lint:check lint:text -- ",
      "pnpm run-p format:text format:prettier -- "
    ],
    "!(src/**/*.{astro,ts,tsx,md,mdx})": [
      "pnpm format:prettier"
    ]
  },
  "scripts": {
    "clean": "rm -rf dist && find src/content/articles -type d -name '_check' -exec rm -rf {} +",
    "predev": "run-s update:ui-data",
    "dev": "astro dev",
    "start": "pnpm dev",
    "prebuild": "run-s clean update:ui-data",
    "build": "astro build",
    "build:prod": "pnpm build && pnpm tsx ./scripts/update-algoliasearch.ts",
    "prepreview": "run-s clean update:ui-data",
    "preview": "astro preview",
    "astro": "astro",
    "lint:ts:content": "eslint 'src/**/*.{astro,ts,tsx}'",
    "lint:ts:codeblock": "tsc --project tsconfig.check.json && eslint 'src/content/articles/**/_check/**/*.tsx'",
    "lint:check": "pnpm update:ui-data && astro check --tsconfig tsconfig.astro.json",
    "lint:text": "textlint 'src/content/**/*.md{,x}'",
    "prelint": "tsx ./scripts/extract-editable-code.ts",
    "lint": "run-p lint:**",
    "format:eslint": "eslint --fix 'src/**/*.{astro,ts,tsx}'",
    "format:prettier": "prettier --write .",
    "format:text": "textlint --fix 'src/content/**/*.md{,x}'",
    "format": "run-p format:*",
    "export:zip-images": "tsx ./scripts/zipImages.ts",
    "update:ui-data": "tsx ./scripts/fetch-ui-data.ts",
    "update:smarthr-ui.css": "tsx scripts/update-smarthr-ui-css.ts",
    "generate:thumbnails": "cd ./scripts/component-thumbnails && pnpm install && cd ../.. && tsx ./scripts/component-thumbnails/componentThumbnails.ts",
    "copy:smarthr-ui-css": "cp node_modules/smarthr-ui/smarthr-ui.css public/",
    "upgrade:smarthr-ui": "pnpm -r upgrade smarthr-ui@latest",
    "postupgrade:smarthr-ui": "run-s copy:smarthr-ui-css generate:thumbnails",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "algoliasearch": "^5.55.1",
    "astro": "^6.3.7",
    "clsx": "^2.1.1",
    "marked": "^18.0.5",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-frame-component": "^5.3.2",
    "react-instantsearch": "^7.38.0",
    "react-instantsearch-core": "^7.38.0",
    "react-live": "^4.1.8",
    "smarthr-normalize-css": "^1.1.0",
    "smarthr-ui": "^96.1.1",
    "styled-components": "^6.4.3",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@eslint/eslintrc": "^3.3.5",
    "@storybook/types": "^8.6.14",
    "@types/adm-zip": "^0.5.8",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/parser": "^8.62.1",
    "adm-zip": "^0.5.18",
    "eslint": "^9.39.4",
    "eslint-config-smarthr": "^14.8.2",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.8.1",
    "gray-matter": "^4.0.3",
    "hast-util-select": "^6.0.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "node-html-parser": "^7.1.0",
    "npm-run-all2": "9.0.2",
    "prettier": "^3.9.4",
    "prettier-config-smarthr": "^1.0.1",
    "prettier-plugin-astro": "^0.14.1",
    "remark": "^15.0.1",
    "remark-emoji": "^5.0.2",
    "sass-embedded": "^1.100.0",
    "sharp": "0.35.2",
    "tailwindcss": "3",
    "textlint": "^15.7.1",
    "textlint-filter-rule-allowlist": "^4.0.0",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-plugin-mdx": "^1.1.0",
    "textlint-rule-preset-smarthr": "^1.37.5",
    "textlint-rule-prh": "^6.1.0",
    "tsx": "^4.22.4",
    "unist-util-visit": "^5.1.0"
  },
  "packageManager": "pnpm@11.9.0"
}
